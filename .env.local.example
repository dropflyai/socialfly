# ==============================================================================
# SocialSync Empire Suite - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your actual API keys
# NEVER commit .env.local to version control!
# ==============================================================================

# ==============================================================================
# DATABASE (Supabase)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ==============================================================================
# AI SERVICES
# ==============================================================================

# Content Generation (Claude Sonnet 4.5 - Primary LLM)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: DeepSeek (Fallback LLM - cheaper alternative)
DEEPSEEK_API_KEY=your_deepseek_key_here

# AI Video Generation Engines (Week 2 - to be added)
KLING_API_KEY=your_kling_api_key_here
VEO3_API_KEY=your_veo3_api_key_here
RUNWAY_API_KEY=your_runway_api_key_here
SEEDANCE_API_KEY=your_seedance_api_key_here

# ==============================================================================
# SOCIAL MEDIA POSTING
# ==============================================================================

# Ayrshare (Instagram, Facebook, LinkedIn posting)
AYRSHARE_API_KEY=your_ayrshare_api_key_here
AYRSHARE_PROFILE_KEY=your_profile_key_here

# Twitter/X API (Week 3 - to be added)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# YouTube Data API (Week 3 - to be added)
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# TikTok (via Playwright stealth - no API key needed)
# We'll use browser automation for TikTok

# ==============================================================================
# AUTOMATION & WORKFLOWS
# ==============================================================================

# n8n Webhook (Optional - for workflow automation)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your_webhook_id
N8N_API_KEY=your_n8n_api_key

# ==============================================================================
# LEGACY (from content-creation - can migrate to Supabase)
# ==============================================================================

# Airtable (Optional - migrate to Supabase recommended)
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id

# ==============================================================================
# PAYMENTS & BILLING (Stripe)
# ==============================================================================

STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_monthly_id
STRIPE_PRO_PRICE_ID=price_pro_monthly_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly_id

# ==============================================================================
# CLOUD STORAGE (Optional - for video/media storage)
# ==============================================================================

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_CLOUD_KEY_FILE=./path/to/service-account.json
GCS_BUCKET_NAME=your_bucket_name

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Dropbox
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token

# ==============================================================================
# PROXIES (for stealth posting - avoid bans)
# ==============================================================================

# GeoSurf Residential Proxies (Week 3)
GEOSURF_PROXY_URL=http://your_username:your_password@proxy.geosurf.io:8080
GEOSURF_USERNAME=your_geosurf_username
GEOSURF_PASSWORD=your_geosurf_password

# Alternative: BrightData, Smartproxy, etc.
# PROXY_URL=http://username:password@proxy.provider.com:port

# ==============================================================================
# MONITORING & ANALYTICS
# ==============================================================================

# Sentry (Error tracking - optional)
SENTRY_DSN=https://your_sentry_dsn_here

# PostHog (Product analytics - optional)
POSTHOG_API_KEY=your_posthog_api_key
NEXT_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key

# Grafana Cloud (Metrics dashboard - optional)
GRAFANA_API_KEY=your_grafana_api_key

# ==============================================================================
# SECURITY & AUTHENTICATION
# ==============================================================================

# NextAuth (if using NextAuth for authentication)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# ==============================================================================
# DEVELOPMENT
# ==============================================================================

# Environment
NODE_ENV=development

# Port (optional - defaults to 3000)
PORT=3000

# ==============================================================================
# FEATURE FLAGS (Optional)
# ==============================================================================

# Enable/disable features during development
FEATURE_AI_VIDEO_GENERATION=false  # Week 2
FEATURE_TIKTOK_POSTING=false       # Week 3
FEATURE_TREND_RADAR=false          # Week 5
FEATURE_STRIPE_BILLING=false       # Week 4
FEATURE_WHITE_LABEL=false          # Week 4

# ==============================================================================
# COST TRACKING (for margin calculations)
# ==============================================================================

# Cost per token (in cents)
KLING_COST_PER_TOKEN=0.0025
VEO3_COST_PER_TOKEN=0.003
RUNWAY_COST_PER_TOKEN=0.004
SEEDANCE_COST_PER_TOKEN=0.002
CLAUDE_COST_PER_TOKEN=0.00015

# Target margin (300% = 3.0)
TARGET_MARGIN=3.0

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================

# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your API keys (minimum required: Supabase + Anthropic + Ayrshare)
# 3. Create Supabase project: https://supabase.com/dashboard
# 4. Run schema: Copy db/schema.sql into Supabase SQL Editor
# 5. Get Anthropic key: https://console.anthropic.com/
# 6. Get Ayrshare key: https://www.ayrshare.com/
# 7. Run: npm run dev
# 8. Visit: http://localhost:3000

# ==============================================================================
# PRIORITY API KEYS (Week 1 - get these first)
# ==============================================================================

# ✅ CRITICAL (app won't run without these):
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - ANTHROPIC_API_KEY

# 🟡 IMPORTANT (needed for full features):
# - AYRSHARE_API_KEY (social posting)

# ⚪ OPTIONAL (can add later):
# - AI video engines (Week 2)
# - Stripe (Week 4)
# - Proxy (Week 3)
# - Monitoring tools

# ==============================================================================
# COST ESTIMATE (with all services)
# ==============================================================================

# Service              | Cost/Month | When Needed
# ---------------------|------------|--------------
# Supabase Pro         | $25        | Week 1 ✅
# Anthropic API        | $60        | Week 1 ✅
# Ayrshare             | $50        | Week 1 ✅
# Kling API            | $100       | Week 2
# Runway API           | $50        | Week 2
# GeoSurf Proxy        | $33        | Week 3
# Vercel Pro           | $20        | Week 1 ✅
# Redis Cloud          | $10        | Week 3
# ---------------------|------------|--------------
# TOTAL                | $348/mo    | (under $423 budget)

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
