# ==============================================================================
# SocialFly - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your actual API keys
# NEVER commit .env.local to version control!
# ==============================================================================

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# DATABASE (Supabase)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ==============================================================================
# AI SERVICES
# ==============================================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ==============================================================================
# TWITTER / X API (OAuth 2.0 with PKCE)
# Apply at: https://developer.twitter.com/en/portal/dashboard
# Required plan: Basic ($100/mo) for tweet.write scope
# ==============================================================================
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# ==============================================================================
# META / INSTAGRAM (Facebook Graph API)
# Apply at: https://developers.facebook.com/apps/
# Requires: Instagram Business/Creator account linked to Facebook Page
# App Review needed for: instagram_content_publish
# ==============================================================================
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ==============================================================================
# TIKTOK (Content Posting API)
# Apply at: https://developers.tiktok.com/
# App Review needed for: video.publish scope
# ==============================================================================
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ==============================================================================
# CRON / SCHEDULER
# ==============================================================================
# Secret for authenticating cron endpoint calls
CRON_SECRET=generate_a_random_secret_here

# ==============================================================================
# PAYMENTS (Stripe - for future monetization)
# ==============================================================================
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==============================================================================
# DEVELOPMENT
# ==============================================================================
NODE_ENV=development
PORT=3000
